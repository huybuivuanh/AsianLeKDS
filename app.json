{
  "expo": {
    "name": "Asian Le KDS",
    "slug": "AsianLeKDS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Asian Le KDS.png",
    "scheme": "asianlekds",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buivuanhhuy.AsianLeKDS",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.buivuanhhuy.AsianLeKDS"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/Asian Le KDS.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/Asian Le KDS.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4a0bda9c-9923-4376-a62a-40f1592e0045"
      }
    }
  }
}
