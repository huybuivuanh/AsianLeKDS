{
  "expo": {
    "name": "AsianLeKDS",
    "slug": "AsianLeKDS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Asian Le KDS.png",
    "scheme": "asianlekds",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Asian Le KDS.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/Asian Le KDS.png",
      "bundleIdentifier": "com.buivuanhhuy.AsianLeKDS",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Asian Le KDS.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.buivuanhhuy.AsianLeKDS"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/Asian Le KDS.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4a0bda9c-9923-4376-a62a-40f1592e0045"
      }
    }
  }
}
